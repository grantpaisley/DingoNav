{
  "name": "DingoNav",
  "short_name": "DingoNav",
  "description": "Offline GPX track follower with turn beeps, heatmap and offline basemap",
  "start_url": "./",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#0e1216",
  "theme_color": "#0e1216",
  "icons": [
    { "src": "icon-192.png", "sizes": "192x192", "type": "image/png" },
    { "src": "icon-512.png", "sizes": "512x512", "type": "image/png" }
  ],
  "file_handlers": [
    {
      "action": "./",
      "accept": {
        "application/x-dingonav": [".dingonav"],
        "application/zip": [".dingonav", ".zip"]
      }
    }
  ]
}
